{
  "expo": {
    "name": "GRANULA",
    "slug": "granula",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon-512.png",
    "scheme": "granula",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#000000",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#000000",
      "resizeMode": "contain",
      "image": "./assets/icon-512.png"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.granula.app",
      "infoPlist": {
        "UIBackgroundModes": ["audio"],
        "NSMicrophoneUsageDescription": "GRANULA использует микрофон для записи сэмплов, из которых синтезируется звук."
      }
    },
    "android": {
      "package": "com.granula.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon-512.png",
        "backgroundColor": "#000000"
      },
      "permissions": ["RECORD_AUDIO", "MODIFY_AUDIO_SETTINGS"]
    },
    "plugins": ["expo-audio", "expo-font"],
    "experiments": {
      "typedRoutes": false
    }
  }
}
